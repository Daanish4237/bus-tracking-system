{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "../dist/api",
    "rootDir": "..",
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "../src/backend/**/*.ts",
    "../src/shared/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts"]
}
